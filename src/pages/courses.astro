---
import CoursesPanel from "@components/CoursesPanel.svelte";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "../utils/content-utils";

// Only pass posts that belong to the "课程笔记" category
const allPosts = await getSortedPostsList();
const coursePosts = allPosts.filter(
	(post) => post.data.category && post.data.category.trim() === "课程笔记",
);
---

<MainGridLayout title="课程笔记">
    <CoursesPanel sortedPosts={coursePosts} client:only="svelte" />
</MainGridLayout>
